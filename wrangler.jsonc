{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2025-12-26",
  "name": "skland-daily-attendance",
  "compatibility_flags": ["nodejs_als"],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "KV","id": "26331060d71a41ac9a5fec9710b0eccf"
    }
  ],
  "triggers": {
    "crons": ["30 0/2 * * *"]
  }
}
